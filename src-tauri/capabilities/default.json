{
  "identifier": "default",
  "description": "Default capabilities for Forge",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:default",
    "shell:allow-execute",
    "shell:allow-open",
    "shell:allow-spawn",
    {
      "identifier": "shell:allow-execute",
      "allow": [{ "name": "*", "sidecar": false }]
    }
  ]
}
