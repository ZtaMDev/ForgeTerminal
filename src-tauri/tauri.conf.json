{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-config-schema/schema.json",
  "productName": "Forge",
  "version": "0.1.0",
  "identifier": "com.forge.terminal",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Forge",
        "width": 960,
        "height": 600,
        "minWidth": 640,
        "minHeight": 400,
        "decorations": false,
        "transparent": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/256x256.png",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "cli": {
      "description": "Forge Terminal Emulator",
      "longDescription": "Launch Forge terminal. Pass a directory path to open a session in that directory.",
      "args": [
        {
          "name": "path",
          "index": 1,
          "takesValue": true,
          "description": "The directory path to open in a new session",
          "short": "p"
        }
      ]
    }
  }
}
