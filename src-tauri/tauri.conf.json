{
  "$schema": "./gen/schemas/desktop-schema.json",
  "productName": "Forge",
  "version": "0.1.0",
  "identifier": "com.forge.terminal",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Forge",
        "width": 960,
        "height": 600,
        "minWidth": 640,
        "minHeight": 400,
        "decorations": false,
        "transparent": false,
        "center": true,
        "visible": false,
        "backgroundColor": [30, 30, 46, 255]
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ],
    "copyright": "MIT Licensed",
    "category": "DeveloperTool",
    "shortDescription": "Terminal Emulator & Multiplexer",
    "longDescription": "Forge is a fast, modern terminal emulator and multiplexer built with Tauri and React. Run multiple terminal sessions in tabs and split panes, navigate with a command palette, and customize every aspect of your workflow.",
    "windows": {
      "nsis": {
        "compression": "lzma",
        "installerIcon": "icons/icon.ico",
        "uninstallerIcon": "icons/icon.ico",
        "displayLanguageSelector": false,
        "languages": ["English"],
        "installMode": "currentUser"
      },
      "wix": {
        "language": "en-US"
      }
    }
  },
  "plugins": {
    "cli": {
      "description": "Forge Terminal Emulator",
      "longDescription": "Launch Forge terminal. Pass a directory path to open a session in that directory.",
      "args": [
        {
          "name": "path",
          "index": 1,
          "takesValue": true,
          "description": "The directory path to open in a new session",
          "short": "p"
        }
      ]
    }
  }
}
